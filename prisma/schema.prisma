generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Enums (v2) ---
enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum TourType {
  DAYS
  NIGHTS
}

enum TransportMode {
  CAR
  BUS
  TRAIN
  PLANE
  BOAT
  WALK
  BIKE
  BICYCLE
  MOTORBIKE
}

enum ImageEntityType {
  DESTINATION
  PACKAGE
  BLOG
  COMMUNITY_POST
}

enum ImageEditSuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blog {
  id         String   @id @default(cuid())
  title      String
  content    String
  authorId   String
  tags       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  authorName String
  imageData  String?

  @@index([createdAt])
}

model Booking {
  id              String    @id @default(cuid())
  userId          String?
  customerId      String?
  firstname       String
  lastname        String
  email           String
  phone           String
  country         String?
  status          String    @default("PENDING")
  // v2 typed status (keep `status` for backward compatibility)
  statusV2        BookingStatus @default(PENDING)
  bookingDate     DateTime?
  numberOfGuests  Int       @default(1)
  specialRequests String?
  destinationName String?
  price           Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([statusV2])
  @@index([customerId, createdAt])
  @@index([email, createdAt])
}

model PackageBooking {
  id              String    @id @default(cuid())
  userId          String?
  customerId      String?
  firstname       String
  lastname        String
  email           String
  phone           String
  country         String?
  status          String    @default("PENDING")
  statusV2        BookingStatus @default(PENDING)
  bookingDate     DateTime?
  numberOfGuests  Int       @default(1)
  specialRequests String?
  packageId       String
  price           Float
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  package         Package   @relation(fields: [packageId], references: [id])
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([packageId, createdAt])
  @@index([userId, createdAt])
  @@index([statusV2])
  @@index([customerId, createdAt])
}

model Package {
  id          String           @id @default(cuid())
  name        String
  location    String
  imageData   String?
  duration    String
  groupSize   String
  price       Float
  description String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  authorId    String
  authorName  String
  included    Included[]
  bookings    PackageBooking[]
  itinerary   PackageItineraryLeg[]

  @@index([createdAt])
  @@index([price])
}

model Included {
  id        String  @id @default(cuid())
  item      String
  packageId String
  package   Package @relation(fields: [packageId], references: [id])

  @@index([packageId])
}

model PackageItineraryLeg {
  id          String   @id @default(cuid())
  packageId   String
  order       Int
  mode        String
  modeV2      TransportMode @default(CAR)
  // Timeline fields (v3) for "tour chuẩn"
  day         Int      @default(1)
  stopTitle   String?
  stopDesc    String?  @db.Text
  stopImage   String?
  mapsQuery   String?
  fromName    String
  toName      String
  distanceKm  Float?
  fromLat     Float?
  fromLng     Float?
  toLat       Float?
  toLng       Float?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  package     Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, order])
  @@index([packageId, day, order])
}

model KeepAlive {
  id     Int     @id @default(autoincrement())
  name   String? @default("")
  random String? @default(uuid())
}

model CommunityPost {
  id          String             @id @default(cuid())
  userId      String?
  authorName  String
  title       String?
  content     String
  imageData   String?
  tags        String?            // comma-separated
  location    String?
  likesCount  Int                @default(0)
  savesCount  Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  comments    CommunityComment[]
  likes       CommunityPostLike[]
  saves       CommunityPostSave[]

  @@index([createdAt])
  @@index([userId, createdAt])
}

model CommunityComment {
  id         String        @id @default(cuid())
  postId     String
  userId     String?
  authorName String
  content    String
  createdAt  DateTime      @default(now())
  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

// Per-user interactions (v2). Keep counts on CommunityPost as denormalized aggregates.
model CommunityPostLike {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

model CommunityPostSave {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

model AIPlannerBooking {
  id              String    @id @default(cuid())
  // Shareable public link token for /trip/[token]
  publicToken     String?   @unique
  customerId      String?
  firstname       String
  lastname        String
  email           String
  phone           String?
  status          String    @default("PENDING")
  statusV2        BookingStatus @default(PENDING)
  bookingDate     DateTime?
  numberOfGuests  Int       @default(1)
  
  // Journey Details
  startLocation   String
  endLocation     String
  transportMode   String
  transportModeV2 TransportMode @default(CAR)
  distanceKm      Float?
  co2Kg           Float?
  
  // AI Generated Data (JSON stringified)
  routePoints     String?   @db.Text
  ecoPoints       String?   @db.Text
  expertInsights  String?   @db.Text
  itemsUsed       String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([customerId, createdAt])
  @@index([email, createdAt])
}

enum EcoActionType {
  EARN_BOOKING
  EARN_CHALLENGE
  EARN_REPORT_VERIFIED
  SPEND_REDEEM
  PENALTY_VIOLATION
}

enum EcoReportStatus {
  PENDING
  VERIFIED
  REJECTED
}

model Customer {
  id              String   @id @default(cuid())
  clerkUserId     String?  @unique
  firstName       String?
  lastName        String?
  fullName        String?
  email           String
  emailNormalized String   @unique
  phone           String?
  phoneNormalized String?
  country         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastSeenAt      DateTime?

  // Eco Features
  ecoPoints       Int      @default(0)
  pointLogs       EcoPointLog[]
  reports         EcoReport[] @relation("Reporter")
  violations      EcoReport[] @relation("Violator")

  bookings        Booking[]
  packageBookings PackageBooking[]
  aiPlannerBookings AIPlannerBooking[]
}

model EcoReward {
  id              String   @id @default(cuid())
  title           String
  description     String   @db.Text
  pointsRequired  Int
  stock           Int      @default(0)
  imageData       String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  redemptions     EcoPointLog[] @relation("RewardRedemption")
}

model EcoPointLog {
  id              String        @id @default(cuid())
  customerId      String
  actionType      EcoActionType
  pointsChange    Int           // Positive for earn, negative for spend/penalty
  description     String?
  rewardId        String?
  createdAt       DateTime      @default(now())
  
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reward          EcoReward?    @relation("RewardRedemption", fields: [rewardId], references: [id])

  @@index([customerId, createdAt])
}

model EcoReport {
  id              String          @id @default(cuid())
  reporterId      String?
  violatorId      String?         // The user who didn't use the tour as an eco-tour
  bookingId       String?         // Optional: link to a specific booking
  packageId       String?
  description     String          @db.Text
  proofImageData  String?
  status          EcoReportStatus @default(PENDING)
  adminNote       String?
  pointsPenalty   Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  reporter        Customer?       @relation("Reporter", fields: [reporterId], references: [id])
  violator        Customer?       @relation("Violator", fields: [violatorId], references: [id])

  @@index([violatorId, status])
  @@index([reporterId, status])
}

model Destination {
  id          String   @id @default(cuid())
  name        String
  country     String
  city        String
  amount      Float
  tags        String
  imageData   String?
  description String
  daysNights  Int
  tourType    String
  tourTypeV2  TourType @default(DAYS)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  latitude    Float?
  longitude   Float?

  @@index([country, city])
  @@index([createdAt])
}

model ImageEditSuggestion {
  id         String                   @id @default(cuid())
  entityType ImageEntityType
  entityId   String
  field      String                   @default("imageData")
  oldValue   String?
  newValue   String
  note       String?
  status     ImageEditSuggestionStatus @default(PENDING)
  appliedAt  DateTime?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  @@index([entityType, entityId])
  @@index([status, createdAt])
}
